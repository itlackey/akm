#!/usr/bin/env bash
# akm-eval-collect — ingest an improve-result.json into a paired-mode summary.
#
# Thin wrapper around scripts/akm-eval/src/collect.ts.

set -euo pipefail

dir="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../_lib.sh
source "$dir/../_lib.sh"

require_bun

exec bun run "$dir/../src/collect.ts" "$@"
