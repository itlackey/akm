#!/usr/bin/env bash
# runs-list — one-line summary per recent improve run.
#
# Usage:
#   runs-list [N] [--stash <path>]
#
# N defaults to 20. Reads from the `improve_runs` table in state.db.
# The legacy `<stash>/.akm/runs/` filesystem layout was archived by
# scripts/migrations/import-fs-improve-runs-to-db.ts; `--stash` is now
# vestigial and only echoed for back-compat (the helper no longer
# touches the filesystem).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=./_lib.sh
source "$SCRIPT_DIR/_lib.sh"

REMAINING_ARGS=()
resolve_stash "$@"
set -- "${REMAINING_ARGS[@]+"${REMAINING_ARGS[@]}"}"

LIMIT="${1:-20}"

db="$(state_db_path)"
if [[ ! -f "$db" ]]; then
  echo "runs-list: state.db not found at $db" >&2
  exit 1
fi

# Pull (id, result_json) for the N most-recent rows. jq turns the
# envelope into the same columns the old jq-on-disk pipeline produced.
{
  printf "ts\tok\tactions\tlint_fixed\tlint_flagged\tmem_written\tmem_considered\tdistill_attempt\tdistill_skipped\trun_id\n"
  sqlite3 -separator $'\x1f' "$db" \
    "SELECT id, result_json FROM improve_runs ORDER BY started_at DESC LIMIT $LIMIT;" \
    | while IFS=$'\x1f' read -r id result_json; do
      [[ -z "$id" ]] && continue
      ts="$(run_ts "$id")"
      printf "%s" "$result_json" | jq -r --arg ts "$ts" --arg id "$id" '
        [
          $ts,
          (.ok | tostring),
          (.actions // [] | length),
          (.lintSummary.fixed // 0),
          (.lintSummary.flagged // 0),
          (.memoryInference.writtenFacts // 0),
          (.memoryInference.considered // 0),
          ([.actions[]? | select(.mode == "distill-attempt" or .mode == "distill")] | length),
          ([.actions[]? | select(.mode == "distill-skipped")] | length),
          $id
        ] | @tsv
      '
    done
} | column -t -s $'\t'
