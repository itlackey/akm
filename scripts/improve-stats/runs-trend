#!/usr/bin/env bash
# runs-trend — TSV trend across the last N runs.
#
# Usage:
#   runs-trend [N] [--stash <path>]
#
# N defaults to 12. Pipe to `column -t` for a table. Reads from the
# `improve_runs` table in state.db (the legacy filesystem layout was
# archived by scripts/migrations/import-fs-improve-runs-to-db.ts).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=./_lib.sh
source "$SCRIPT_DIR/_lib.sh"

REMAINING_ARGS=()
resolve_stash "$@"
set -- "${REMAINING_ARGS[@]+"${REMAINING_ARGS[@]}"}"

LIMIT="${1:-12}"

db="$(state_db_path)"
if [[ ! -f "$db" ]]; then
  echo "runs-trend: state.db not found at $db" >&2
  exit 1
fi

{
  printf "ts\tlint_fixed\tlint_flagged\tmem_written\tmem_considered\tgraph_entities\tgraph_relations\tdistill_attempt\tdistill_skipped\tplanned\tactions\n"
  # SELECT newest N, then reverse so the table reads oldest→newest top
  # down (matches the old `ls -t … | tac` ordering).
  sqlite3 -separator $'\x1f' "$db" "
    SELECT id, result_json FROM (
      SELECT id, result_json, started_at FROM improve_runs
      ORDER BY started_at DESC
      LIMIT $LIMIT
    ) ORDER BY started_at ASC;
  " | while IFS=$'\x1f' read -r id result_json; do
    [[ -z "$id" ]] && continue
    ts="$(run_ts "$id")"
    printf "%s" "$result_json" | jq -r --arg ts "$ts" '
      [
        $ts,
        (.lintSummary.fixed // 0),
        (.lintSummary.flagged // 0),
        (.memoryInference.writtenFacts // 0),
        (.memoryInference.considered // 0),
        (.graphExtraction.totalEntities // 0),
        (.graphExtraction.totalRelations // 0),
        ([.actions[]? | select(.mode == "distill-attempt" or .mode == "distill")] | length),
        ([.actions[]? | select(.mode == "distill-skipped")] | length),
        (.plannedRefs // [] | length),
        (.actions // [] | length)
      ] | @tsv
    '
  done
}
