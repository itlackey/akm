#!/usr/bin/env bash
# run-show — DEPRECATED thin shim around `akm-eval-collect`.
#
# The bespoke jq pipeline was superseded by the akm-eval toolkit's
# improve-run ingestion (`scripts/akm-eval/bin/akm-eval-collect`), which
# emits the equivalent per-run summary as deterministic JSON (and
# optionally Markdown). This shim preserves the old `run-show
# <id|latest>` invocation for muscle memory.
#
# Usage:
#   run-show <run-id|latest> [--stash <path>] [--format json|md]
#
# Prints the akm-eval invocation to stderr before exec'ing so the new
# entry point is discoverable.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
EVAL_BIN="$REPO_ROOT/scripts/akm-eval/bin/akm-eval-collect"

if [[ ! -x "$EVAL_BIN" ]]; then
  echo "run-show: missing $EVAL_BIN (akm-eval toolkit not installed?)" >&2
  exit 2
fi

if [[ $# -lt 1 ]]; then
  echo "usage: run-show <run-id|latest> [--stash <path>] [--format json|md]" >&2
  exit 2
fi

RUN_ID="$1"
shift

echo "[run-show] forwarding to: $EVAL_BIN --from-improve-run $RUN_ID $*" >&2
exec "$EVAL_BIN" --from-improve-run "$RUN_ID" "$@"
