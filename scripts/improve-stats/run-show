#!/usr/bin/env bash
# run-show — pretty per-run summary.
#
# Usage:
#   run-show <run-id|latest> [--stash <path>]
#
# Resolves "latest" / "last" to the most recent run directory.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=./_lib.sh
source "$SCRIPT_DIR/_lib.sh"

REMAINING_ARGS=()
resolve_stash "$@"
set -- "${REMAINING_ARGS[@]+"${REMAINING_ARGS[@]}"}"

if [[ $# -lt 1 ]]; then
  echo "usage: run-show <run-id|latest> [--stash <path>]" >&2
  exit 2
fi

path="$(run_path "$1")"
echo "# $path"
echo

jq '{
  ok,
  scope,
  plannedRefs: (.plannedRefs | length),
  actions: (.actions | length),
  modes: (
    [.actions[]? | .mode]
    | group_by(.)
    | map({(.[0]): length})
    | add
  ),
  memoryInference,
  memorySummary,
  graphExtraction: {
    considered: .graphExtraction.considered,
    extracted: .graphExtraction.extracted,
    entities: .graphExtraction.totalEntities,
    relations: .graphExtraction.totalRelations,
    written: .graphExtraction.written,
    warnings: (.graphExtraction.warnings | length)
  },
  stalenessDetection: {
    considered: .stalenessDetection.considered,
    deprecated: .stalenessDetection.deprecated,
    confirmed: .stalenessDetection.confirmed,
    durationMs: .stalenessDetection.durationMs
  },
  evalCasesWritten,
  orphansPurged,
  lintSummary
}' "$path"
