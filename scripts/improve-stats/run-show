#!/usr/bin/env bash
# run-show — show a full improve-run summary.
#
# Usage:
#   run-show <run-id|latest> [--format json|md] [--stash <path>]
#
# Pulls the run envelope from the `improve_runs` table in state.db and
# forwards to `akm-eval-collect`, which renders the rich summary. The
# DB row is materialised to a temp directory in the legacy
# `<stash>/.akm/runs/<id>/improve-result.json` shape so the collector
# can ingest it unchanged. The temp dir is removed on exit.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
EVAL_BIN="$REPO_ROOT/scripts/akm-eval/bin/akm-eval-collect"
# shellcheck source=./_lib.sh
source "$SCRIPT_DIR/_lib.sh"

if [[ ! -x "$EVAL_BIN" ]]; then
  echo "run-show: missing $EVAL_BIN (akm-eval toolkit not installed?)" >&2
  exit 2
fi

if [[ $# -lt 1 ]]; then
  echo "usage: run-show <run-id|latest> [--format json|md] [--stash <path>]" >&2
  exit 2
fi

INPUT_ID="$1"
shift

RUN_ID="$(resolve_run_id "$INPUT_ID")"
TMP="$(stage_run_to_tmp "$RUN_ID")"
trap 'rm -rf "$TMP"' EXIT

echo "[run-show] forwarding to: $EVAL_BIN --stash $TMP --from-improve-run $RUN_ID $*" >&2
exec "$EVAL_BIN" --stash "$TMP" --from-improve-run "$RUN_ID" "$@"
