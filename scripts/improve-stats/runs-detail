#!/usr/bin/env bash
# runs-detail — per-run breakdown across every stage of improve.
#
# Where `runs-list` shows the slim "what fired and how much" view,
# `runs-detail` walks the result envelope and surfaces every stage —
# reflect outcomes, distill outcomes, consolidation, memory-inference,
# graph extraction, staleness — so a regression or recovery is visible
# at a glance.
#
# Usage:
#   runs-detail [N]
#   runs-detail --since <iso> [--until <iso>]
#   runs-detail --json [--since <iso>] [--until <iso>] [N]
#
# Defaults: N = 12. Without --since/--until shows the N most-recent
# runs. With a window, N caps the rows after the window filter.
#
# --json prints one JSON object per run on stdout (jsonlines), ready
# to pipe into another jq pipeline for ad-hoc analysis.
#
# Reads from the `improve_runs` table in state.db.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=./_lib.sh
source "$SCRIPT_DIR/_lib.sh"

LIMIT=12
SINCE=""
UNTIL=""
FORMAT="table"

REMAINING_ARGS=()
resolve_stash "$@"
set -- "${REMAINING_ARGS[@]+"${REMAINING_ARGS[@]}"}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --since) SINCE="$2"; shift 2 ;;
    --since=*) SINCE="${1#--since=}"; shift ;;
    --until) UNTIL="$2"; shift 2 ;;
    --until=*) UNTIL="${1#--until=}"; shift ;;
    --json) FORMAT="json"; shift ;;
    -h|--help)
      sed -n '2,18p' "$0"; exit 0
      ;;
    *)
      if [[ "$1" =~ ^[0-9]+$ ]]; then LIMIT="$1"; shift
      else echo "runs-detail: unknown argument: $1" >&2; exit 2
      fi
      ;;
  esac
done

db="$(state_db_path)"
if [[ ! -f "$db" ]]; then
  echo "runs-detail: state.db not found at $db" >&2
  exit 1
fi

# Build the WHERE clause without exposing user input directly to SQL.
WHERE=""
if [[ -n "$SINCE" ]]; then
  WHERE="WHERE started_at >= '$(sql_quote "$SINCE")'"
fi
if [[ -n "$UNTIL" ]]; then
  if [[ -z "$WHERE" ]]; then
    WHERE="WHERE started_at < '$(sql_quote "$UNTIL")'"
  else
    WHERE="$WHERE AND started_at < '$(sql_quote "$UNTIL")'"
  fi
fi

# Per-run jq projection. Mirrors the buckets we care about; everything
# missing defaults to 0 so the table stays rectangular across schema
# drift.
project() {
  jq -r --arg ts "$1" --arg id "$2" '
    {
      ts: $ts,
      id: $id,
      ok: (.ok // false),
      actions: (.actions // [] | length),

      reflect_ok: ([.actions[]? | select(.mode=="reflect" and .result.ok==true)] | length),
      reflect_failed: ([.actions[]? | select(.mode=="reflect-failed")] | length),
      reflect_cooldown: ([.actions[]? | select(.mode=="reflect-cooldown")] | length),
      reflect_skipped: ([.actions[]? | select(.mode=="reflect-skipped")] | length),

      distill_queued: ([.actions[]? | select(.mode=="distill" and .result.outcome=="queued")] | length),
      distill_llm_failed: ([.actions[]? | select(.mode=="distill" and .result.outcome=="llm_failed")] | length),
      distill_quality_rejected: ([.actions[]? | select(.mode=="distill" and .result.outcome=="quality_rejected")] | length),
      distill_config_disabled: ([.actions[]? | select(.mode=="distill" and .result.outcome=="config_disabled")] | length),
      distill_skipped: ([.actions[]? | select(.mode=="distill-skipped")] | length),

      consolidate_processed: (.consolidation.processed // 0),
      consolidate_promoted: ((.consolidation.promoted // []) | length),
      consolidate_merged: (.consolidation.merged // 0),
      consolidate_deleted: (.consolidation.deleted // 0),
      consolidate_contradicted: (.consolidation.contradicted // 0),
      consolidate_ms: (.consolidation.durationMs // 0),

      mem_considered: (.memoryInference.considered // 0),
      mem_written: (.memoryInference.writtenFacts // 0),
      mem_skipped: (.memoryInference.skippedNoFacts // 0),

      graph_files: (.graphExtraction.filesProcessed // .graphExtraction.extracted // 0),
      graph_entities: (.graphExtraction.totalEntities // 0),
      graph_relations: (.graphExtraction.totalRelations // 0),

      cleanup_archived_super: (.memoryCleanup.archivedSuperseded // 0),
      cleanup_archived_stale: (.memoryCleanup.archivedStale // 0),
      cleanup_deleted: (.memoryCleanup.deletedDerived // 0),

      staleness_flagged: (.stalenessDetection.flagged // 0),
      orphans_purged: (.orphansPurged // 0),
      proposals_expired: (.proposalsExpired // 0),

      lint_fixed: (.lintSummary.fixed // 0),
      lint_flagged: (.lintSummary.flagged // 0)
    }
  '
}

# Execute the query, then project each row to a JSON object.
collect_rows() {
  sqlite3 -separator $'\x1f' "$db" "
    SELECT id, result_json FROM improve_runs
    $WHERE
    ORDER BY started_at DESC
    LIMIT $LIMIT
  " | while IFS=$'\x1f' read -r id rj; do
    [[ -z "$id" ]] && continue
    ts="$(run_ts "$id")"
    printf "%s" "$rj" | project "$ts" "$id"
  done
}

if [[ "$FORMAT" == "json" ]]; then
  collect_rows
  exit 0
fi

# Table view — TSV with all stages, run through `column -t` for
# readability. Header tracks the project() shape.
{
  printf "ts\tok\tactions\trefl_ok/fail/cd/skip\tdistill_q/llm-fail/qrej/cfg/skip\tcons_proc/promo/merge/del\tmem_cons/written/skip\tgraph_f/e/r\torphans\tlint_f/fl\n"
  collect_rows | jq -r '[
    .ts,
    (.ok | tostring),
    .actions,
    "\(.reflect_ok)/\(.reflect_failed)/\(.reflect_cooldown)/\(.reflect_skipped)",
    "\(.distill_queued)/\(.distill_llm_failed)/\(.distill_quality_rejected)/\(.distill_config_disabled)/\(.distill_skipped)",
    "\(.consolidate_processed)/\(.consolidate_promoted)/\(.consolidate_merged)/\(.consolidate_deleted)",
    "\(.mem_considered)/\(.mem_written)/\(.mem_skipped)",
    "\(.graph_files)/\(.graph_entities)/\(.graph_relations)",
    .orphans_purged,
    "\(.lint_fixed)/\(.lint_flagged)"
  ] | @tsv'
} | column -t -s $'\t'
