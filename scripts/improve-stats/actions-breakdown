#!/usr/bin/env bash
# actions-breakdown — DEPRECATED thin shim around `akm-eval-collect`.
#
# The hand-rolled jq pipeline (mode counts + distill/reflect skip
# reasons) is now first-class data on the akm-eval-collect summary:
# `actionsByMode`, `actionsByOutcome`, and `proposalsByMode` all land in
# the JSON output. Reflect-failure classification (schema-shape vs
# content-policy vs gate-refused) now lives in the
# `reflect-failure-breakdown` eval case under
# `scripts/akm-eval/cases/improve-smoke/`.
#
# Usage:
#   actions-breakdown <run-id|latest> [--stash <path>] [--format json|md]
#
# Prints the akm-eval invocation to stderr before exec'ing so the new
# entry point is discoverable.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
EVAL_BIN="$REPO_ROOT/scripts/akm-eval/bin/akm-eval-collect"

if [[ ! -x "$EVAL_BIN" ]]; then
  echo "actions-breakdown: missing $EVAL_BIN (akm-eval toolkit not installed?)" >&2
  exit 2
fi

if [[ $# -lt 1 ]]; then
  echo "usage: actions-breakdown <run-id|latest> [--stash <path>] [--format json|md]" >&2
  exit 2
fi

RUN_ID="$1"
shift

echo "[actions-breakdown] forwarding to: $EVAL_BIN --from-improve-run $RUN_ID $*" >&2
echo "[actions-breakdown] reflect classification now lives in:" >&2
echo "[actions-breakdown]   scripts/akm-eval/bin/akm-eval-run --suite improve-smoke" >&2
echo "[actions-breakdown]   (case: reflect-failure-breakdown)" >&2
exec "$EVAL_BIN" --from-improve-run "$RUN_ID" "$@"
