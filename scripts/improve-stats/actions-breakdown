#!/usr/bin/env bash
# actions-breakdown — actions-by-mode/outcome breakdown for a single run.
#
# Usage:
#   actions-breakdown <run-id|latest> [--format json|md] [--stash <path>]
#
# Pulls the run envelope from the `improve_runs` table in state.db,
# stages it back into the legacy `<stash>/.akm/runs/<id>/improve-result.json`
# shape under a temp dir, then forwards to `akm-eval-collect` whose
# `actionsByMode`, `actionsByOutcome`, and `proposalsByMode` cover the
# old jq pipeline. The temp dir is removed on exit.
#
# Reflect-failure classification (schema-shape vs content-policy vs
# gate-refused) lives in the `reflect-failure-breakdown` eval case:
#   scripts/akm-eval/bin/akm-eval-run --suite improve-smoke

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
EVAL_BIN="$REPO_ROOT/scripts/akm-eval/bin/akm-eval-collect"
# shellcheck source=./_lib.sh
source "$SCRIPT_DIR/_lib.sh"

if [[ ! -x "$EVAL_BIN" ]]; then
  echo "actions-breakdown: missing $EVAL_BIN (akm-eval toolkit not installed?)" >&2
  exit 2
fi

if [[ $# -lt 1 ]]; then
  echo "usage: actions-breakdown <run-id|latest> [--format json|md] [--stash <path>]" >&2
  exit 2
fi

INPUT_ID="$1"
shift

RUN_ID="$(resolve_run_id "$INPUT_ID")"
TMP="$(stage_run_to_tmp "$RUN_ID")"
trap 'rm -rf "$TMP"' EXIT

echo "[actions-breakdown] forwarding to: $EVAL_BIN --stash $TMP --from-improve-run $RUN_ID $*" >&2
exec "$EVAL_BIN" --stash "$TMP" --from-improve-run "$RUN_ID" "$@"
