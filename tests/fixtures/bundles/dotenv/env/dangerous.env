# INVALID-ish (fixture, intentional): contains dangerous keys that can hijack
# process execution when injected via `akm env run`. Exercises the
# dangerous-vault-key scan. The VALUES here are placeholders — akm never
# indexes or prints env values; only key NAMES are surfaced.
PATH=/tmp/evil:/usr/bin
NODE_OPTIONS=--require /tmp/evil.js
APP_TOKEN=placeholder-not-real
