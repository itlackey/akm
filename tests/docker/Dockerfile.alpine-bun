# Alpine 3.19 — bun install method (musl libc)
FROM alpine:3.19

RUN apk add --no-cache curl unzip bash git ca-certificates gcompat libstdc++

# Install bun (requires gcompat for musl)
RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/root/.bun/bin:${PATH}"

# Install dependencies first (cached until package.json/bun.lock change)
WORKDIR /opt/akm
COPY package.json bun.lock* ./
RUN --mount=type=cache,target=/root/.bun/install/cache bun install --frozen-lockfile

# Copy source and build (only this layer invalidates on code changes)
COPY tsconfig.json tsconfig.build.json biome.json ./
COPY src/ src/
RUN bun run build

# Make akm available globally via bun link
RUN bun link

# Copy smoke test
COPY tests/docker/smoke-test.sh /opt/smoke-test.sh
RUN chmod +x /opt/smoke-test.sh

ENV AKM_INSTALL_METHOD="bun"
CMD ["/opt/smoke-test.sh"]
