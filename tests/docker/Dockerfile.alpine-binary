# Alpine 3.19 — compiled binary install method (musl libc)
FROM alpine:3.19

RUN apk add --no-cache bash git ca-certificates gcompat libstdc++

# Copy pre-built binary
COPY tests/docker/.build/akm /usr/local/bin/akm
RUN chmod +x /usr/local/bin/akm

# Copy smoke test
COPY tests/docker/smoke-test.sh /opt/smoke-test.sh
RUN chmod +x /opt/smoke-test.sh

ENV AKM_INSTALL_METHOD="binary"
CMD ["/opt/smoke-test.sh"]
