# Ubuntu 22.04 — bun install method
FROM ubuntu:22.04

RUN apt-get update && apt-get install -y --no-install-recommends \
      curl unzip ca-certificates git \
    && rm -rf /var/lib/apt/lists/*

# Install bun
RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/root/.bun/bin:${PATH}"

# Copy project source and build
WORKDIR /opt/akm
COPY package.json bun.lock* tsconfig.json biome.json ./
COPY src/ src/
RUN bun install && bun run build

# Make akm available globally via bun link
RUN bun link

# Copy smoke test
COPY tests/docker/smoke-test.sh /opt/smoke-test.sh
RUN chmod +x /opt/smoke-test.sh

ENV AKM_INSTALL_METHOD="bun"
CMD ["/opt/smoke-test.sh"]
