exports[`default improve strategies (#552) complete resolved trees are pinned for all built-ins: reflect-distill 1`] = `
{
  "config": {
    "description": "Reflect + distill pass — reflect, distill, memoryInference, and proposal triage (promote); proactiveMaintenance/consolidate/graphExtraction/extract off. Sync disabled: an interrupted run would otherwise leave an uncommitted backlog.",
    "processes": {
      "consolidate": {
        "allowedTypes": [
          "memory",
        ],
        "enabled": false,
        "minPoolSize": 500,
      },
      "distill": {
        "allowedTypes": [
          "memory",
        ],
        "enabled": true,
        "requirePlannedRefs": true,
      },
      "extract": {
        "enabled": false,
        "minNewSessions": 1,
        "timeoutMs": 300000,
        "triage": {
          "enabled": true,
          "minScore": 2,
        },
      },
      "graphExtraction": {
        "enabled": false,
      },
      "memoryInference": {
        "enabled": true,
      },
      "proactiveMaintenance": {
        "dueDays": 30,
        "enabled": false,
        "maxPerRun": 15,
      },
      "reflect": {
        "allowedTypes": [
          "agent",
          "command",
          "knowledge",
          "lesson",
          "memory",
          "skill",
          "workflow",
        ],
        "enabled": true,
        "limit": 25,
      },
      "triage": {
        "applyMode": "promote",
        "enabled": true,
        "judgment": {},
        "maxAcceptsPerRun": 15,
        "maxDiffLines": 200,
        "policy": "personal-stash",
      },
      "validation": {
        "enabled": false,
      },
    },
    "sync": {
      "enabled": false,
      "push": true,
    },
  },
  "name": "reflect-distill",
}
`;

