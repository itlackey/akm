exports[`default improve strategies (#552) complete resolved trees are pinned for all built-ins: default 1`] = `
{
  "config": {
    "description": "Standard improve pass — reflect, distill, consolidate, memory inference, graph extraction, and validation; improve-stage extract and proactive maintenance off.",
    "processes": {
      "consolidate": {
        "allowedTypes": [
          "memory",
        ],
        "enabled": true,
        "minPoolSize": 500,
      },
      "distill": {
        "allowedTypes": [
          "memory",
        ],
        "enabled": true,
        "requirePlannedRefs": true,
      },
      "extract": {
        "enabled": false,
        "triage": {
          "enabled": true,
          "minScore": 2,
        },
      },
      "graphExtraction": {
        "enabled": true,
      },
      "memoryInference": {
        "enabled": true,
      },
      "proactiveMaintenance": {
        "dueDays": 30,
        "enabled": false,
        "maxPerRun": 15,
      },
      "reflect": {
        "allowedTypes": [
          "agent",
          "command",
          "knowledge",
          "lesson",
          "memory",
          "skill",
          "workflow",
        ],
        "enabled": true,
        "limit": 25,
      },
      "triage": {
        "applyMode": "queue",
        "enabled": false,
        "policy": "personal-stash",
      },
      "validation": {
        "enabled": true,
      },
    },
    "sync": {
      "enabled": true,
      "push": true,
    },
  },
  "name": "default",
}
`;

