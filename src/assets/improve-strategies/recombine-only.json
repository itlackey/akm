{
  "description": "Recombine-only pass — cross-episodic recombination (#609) over graph entities, excluding session/checkpoint telemetry; all generative/extract/triage passes off.",
  "processes": {
    "reflect": { "enabled": false },
    "distill": { "enabled": false },
    "consolidate": { "enabled": false },
    "memoryInference": { "enabled": false },
    "graphExtraction": { "enabled": false },
    "extract": { "enabled": false },
    "triage": { "enabled": false },
    "recombine": {
      "enabled": true,
      "minClusterSize": 3,
      "maxClustersPerRun": 5,
      "maxClusterSize": 12,
      "excludeTags": ["session", "claude", "opencode", "ses"],
      "relatednessSource": "both"
    }
  },
  "sync": { "push": true, "message": "akm recombine: {accepted} accepted, {refs} refs @ {timestamp}" }
}
