{
  "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "error"
      }
    }
  },
  "files": {
    "includes": [
      "src/**",
      "tests/**",
      "scripts/*.ts",
      "!src/assets/templates/html",
      "!tests/fixtures/goldens/**/*.json",
      "!tests/fixtures/format-family-goldens/**/*.json"
    ]
  },
  "overrides": [
    {
      "includes": [
        "tests/env-secret-tokens.test.ts",
        "tests/integration/env-path-run.test.ts",
        "tests/integration/env-run.test.ts",
        "tests/integration/commands/env-set-unset.test.ts",
        "tests/workflows/program-expressions.test.ts",
        "tests/integration/workflows/program-parser.test.ts",
        "tests/workflows/ir-compile.test.ts",
        "tests/integration/workflows/native-executor.test.ts",
        "tests/integration/workflows/conformance/conformance.test.ts"
      ],
      "linter": { "rules": { "suspicious": { "noTemplateCurlyInString": "off" } } }
    },
    {
      "includes": ["scripts/lint-devto-posts.ts"],
      "linter": { "rules": { "suspicious": { "noControlCharactersInRegex": "off" } } }
    }
  ]
}
