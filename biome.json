{
  "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn"
      }
    }
  },
  "files": {
    "includes": ["src/**", "tests/**"]
  },
  "overrides": [
    {
      "includes": [
        "tests/env-secret-tokens.test.ts",
        "tests/env-path-run.test.ts",
        "tests/commands/env-set-unset.test.ts"
      ],
      "linter": { "rules": { "suspicious": { "noTemplateCurlyInString": "off" } } }
    }
  ]
}
