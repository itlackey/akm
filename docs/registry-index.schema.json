{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agentikit Registry Index",
  "description": "Static index of discoverable kits for akm search --source registry",
  "type": "object",
  "required": ["version", "updatedAt", "kits"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for forward compatibility"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last index generation"
    },
    "kits": {
      "type": "array",
      "items": { "$ref": "#/definitions/RegistryKit" }
    }
  },
  "definitions": {
    "RegistryKit": {
      "type": "object",
      "required": ["id", "name", "ref", "source"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique stable identifier, e.g. 'npm:@itlackey/openkit' or 'github:itlackey/dimm-city-kit'"
        },
        "name": {
          "type": "string",
          "description": "Human-readable display name"
        },
        "description": {
          "type": "string",
          "description": "One-line summary for search results"
        },
        "ref": {
          "type": "string",
          "description": "Install ref passable to `akm add`, e.g. '@itlackey/openkit' or 'itlackey/dimm-city-kit'"
        },
        "source": {
          "type": "string",
          "enum": ["npm", "github", "git"],
          "description": "Registry source type"
        },
        "homepage": {
          "type": "string",
          "format": "uri",
          "description": "URL for more information"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Searchable keywords/categories"
        },
        "assetTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["tool", "skill", "command", "agent", "knowledge", "script"]
          },
          "description": "What kind of stash assets this kit provides"
        },
        "author": {
          "type": "string"
        },
        "license": {
          "type": "string"
        },
        "latestVersion": {
          "type": "string",
          "description": "Most recent version/tag for display"
        }
      }
    }
  }
}
