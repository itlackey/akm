// AKM v2 Configuration — Annotated Example
//
// Schema reference: docs/technical/reflect-llm-migration.md
// Full field spec:  schemas/akm-config.v2.json (after Phase 1 lands)
//
// FILE LOCATIONS
//   User-level (applies everywhere):   ~/.config/akm/config.json
//   Project-level (overlays user):     <project>/.akm/config.json
//   Layering rule: project keys win over user keys.
//
// ENV VAR RESOLUTION
//   ${VAR} placeholders are expanded at load time. Never store real keys in this file.
//   AKM_LLM_API_KEY            — legacy; still works; injected into profiles.llm[defaults.llm].apiKey
//   AKM_PROFILE_<NAME>_API_KEY — per-profile override; NAME is upper-cased profile key with hyphens
//                                replaced by underscores, e.g. AKM_PROFILE_OPENAI_JUDGE_API_KEY
//
// MIGRATION
//   Configs without configVersion (or with configVersion < 2) are auto-migrated at load time.
//   A timestamped backup is written before any in-place rewrite.
//   Set AKM_NO_AUTO_MIGRATE=1 to suppress the rewrite (useful in CI read-only mounts).
//   Manual path: akm config migrate [--dry-run]
//
// SCOPE NOTES
//   • Three modes: "llm" (direct HTTP), "agent" (opencode/claude CLI subprocess),
//     "sdk" (in-process opencode programmatic API). The Anthropic / Claude Agent
//     SDK is NOT supported — opencode is the only agent runtime, whether via CLI
//     or in-process.
//   • No tasks section in config. Task definitions are stash YAMLs (<stash>/tasks/*.yml)
//     that carry their own mode + profile fields.
//   • No improve.schedule in config. Scheduling lives in stash task YAMLs that wrap
//     `akm improve` calls.
{
  // configVersion drives load-time migration. Omitting it (or setting < 2) triggers
  // auto-migrate. Setting 2 here tells the loader the file is already in the new shape.
  "configVersion": 2,

  "$schema": "https://itlackey.github.io/akm/schemas/akm-config.v2.json",

  // ── LLM + Agent Profiles ────────────────────────────────────────────────────
  // Declare every connection once here. Processes reference profiles by name.
  // No more copy-pasting endpoint/apiKey into each feature override.
  "profiles": {

    // profiles.llm — OpenAI-compatible chat-completion endpoints.
    // Used by processes whose mode is "llm".
    "llm": {

      // Cheap, fast workhorse: reflect, consolidate, graph-extract, memory-improve.
      // supportsJsonSchema enables OpenAI structured-output (response_format: json_schema)
      // which eliminates JSON parse failures for capable providers.
      "openai-mini": {
        "endpoint": "https://api.openai.com/v1/chat/completions",
        "model": "gpt-4o-mini",
        "apiKey": "${OPENAI_API_KEY}",
        "temperature": 0.3,
        "supportsJsonSchema": true
      },

      // High-quality judge: distill quality scoring.
      // maxTokens set here because distill prompts produce longer judgement prose.
      // Replaces the old config.llm.judgeModel pattern.
      "openai-judge": {
        "endpoint": "https://api.openai.com/v1/chat/completions",
        "model": "gpt-4o",
        "apiKey": "${OPENAI_API_KEY}",
        "temperature": 0.2,
        "maxTokens": 4096,
        "supportsJsonSchema": true
      },

      // Local Ollama — no apiKey needed. Falls back to prompt-contract JSON
      // (no supportsJsonSchema) because local endpoints vary.
      // Good for offline runs or cost-zero experimentation.
      "ollama-local": {
        "endpoint": "http://localhost:11434/v1/chat/completions",
        "model": "qwen2.5-coder",
        "temperature": 0.4,
        "contextLength": 32768
      },

      // LM Studio — the user's current local inference server (192.168.0.99).
      // Useful for embedding-aligned reflect when using the same server.
      "lmstudio-local": {
        "endpoint": "http://192.168.0.99:1234/v1/chat/completions",
        "model": "mistralai/ministral-3b",
        "temperature": 0.3,
        "contextLength": 131072,
        "concurrency": 1
      }
    },

    // profiles.agent — opencode/claude profiles. Used by mode "agent" (CLI
    // subprocess) and mode "sdk" (in-process opencode programmatic API).
    // platform values:
    //   "opencode"     — opencode CLI subprocess
    //   "claude"       — Claude Code CLI subprocess (--print mode)
    //   "opencode-sdk" — in-process opencode via its programmatic API
    // No "claude-code" (the CLI builder is registered as "claude").
    // No Anthropic SDK / Claude Agent SDK — removed in v2.
    "agent": {

      // Primary opencode CLI agent. The default agent runtime for the project.
      // ~30s/call due to subprocess startup; full opencode tool + plugin access.
      "opencode-default": {
        "platform": "opencode",
        "bin": "opencode",
        "args": ["run"]
      },

      // Claude Code CLI (non-interactive --print mode). Good for propose and
      // tasks where you prefer Claude tooling over opencode's.
      "claude-cli": {
        "platform": "claude",
        "bin": "claude",
        "args": ["--print"]
      },

      // In-process opencode via its programmatic API. ~10-15s/call (no subprocess
      // startup), same tool/plugin surface as the CLI. Field shape mirrors what
      // opencode's SDK init accepts — workspace dir, model, optional tools list.
      // Use for tool-needing processes (propose) where you want subprocess speed.
      "opencode-sdk": {
        "platform": "opencode-sdk",
        "workspace": "${PWD}",
        "model": "opencode/big-pickle"
      }
    }
  },

  // ── Defaults ────────────────────────────────────────────────────────────────
  // Fallback profile names when a process entry doesn't specify one.
  // Used when: no improve.processes entry exists, or the entry omits "profile".
  // Also the target for AKM_LLM_API_KEY injection and akm config set llm.* shortcuts.
  "defaults": {
    "llm": "openai-mini",
    "agent": "opencode-default",
    // Section-level defaults that used to live as siblings of processes.
    // CLI flags still override (--limit 50, --preset fast).
    "improve": {
      "limit": 25,           // default refs per improve run; overridden by --limit
      "preset": "custom"     // "fast" | "thorough" | "mixed" | "custom"
    }
  },

  // ── Features — Single Tree for Every Named Operation ────────────────────────
  // features.<section>.<process> is the canonical home for every LLM/agent
  // operation in the app. Each entry uses the unified shape; shorthand
  // forms allowed:
  //
  //   "X": true                       // enabled with defaults
  //   "X": false                      // disabled — caller short-circuits
  //   "X": { "profile": "..." }       // enabled, pinned profile
  //   "X": { "enabled": true, "mode": "llm", "profile": "...",
  //          "timeoutMs": 60000, "options": { ...process-specific... } }
  //
  // Process-specific tuning lives under "options" — e.g. reflect's cooldown
  // table sits at features.improve.reflect.options.cooldown rather than as
  // a sibling of the process entry. Per-process options schemas are known
  // to the parser; unknown keys warn-and-ignore.
  //
  // The v1 top-level "features" block (boolean flags) collapses into this
  // tree — every former flag is now a leaf with enabled:true/false.
  "features": {

    // ── Improve Pipeline ────────────────────────────────────────────────────
    // Operations during `akm improve`. Names overlapping v1 feature flags
    // use the feature-flag spelling (memory_consolidation, graph_extraction,
    // feedback_distillation). No "schedule" — that lives in stash task YAMLs.
    "improve": {

      // reflect: direct LLM call — 3-5x faster than agent. Multi-turn
      // self-refine on iter 2+, structured output via supportsJsonSchema.
      "reflect": {
        "mode": "llm",
        "profile": "openai-mini",
        "timeoutMs": 90000,
        "options": {
          // Per-asset-type reflect cooldown in days. Replaces the v1
          // improve.reflectCooldownByType key. Only list types you want
          // to override from built-in defaults (memory=2, lesson=7,
          // workflow/skill/agent/command/knowledge/script/wiki=30, task=60).
          "cooldown": {
            "memory":    2,
            "lesson":    7,
            "workflow":  14,
            "knowledge": 30,
            "task":      60
          },
          // Optional: self-refine cap. Defaults to built-in (3).
          "maxRefineIters": 3
        }
      },

      // distill: quality judgement — uses the larger model for better scoring.
      "distill": {
        "mode": "llm",
        "profile": "openai-judge",
        "timeoutMs": 120000
      },

      // memory_consolidation (was: features.memory_consolidation + improve.consolidate):
      // memory deduplication. Cheap model, high volume.
      "memory_consolidation": { "mode": "llm", "profile": "openai-mini" },

      // graph_extraction during improve: skip — already handled at index time.
      // Shorthand `false` disables for the improve cycle without affecting
      // features.index.graph_extraction.
      "graph_extraction": false,

      // propose: needs agent tool access (reads stash, writes proposals).
      // sdk mode = in-process opencode → tools available, no subprocess tax.
      "propose": { "mode": "sdk", "profile": "opencode-sdk" },

      // memory_improve: cheap LLM workhorse — pure text-in/JSON-out.
      "memory_improve": { "mode": "llm", "profile": "openai-mini" },

      // feedback_distillation: turn collected feedback into lessons. Shorthand
      // `true` = enabled with defaults (mode:llm, profile:defaults.llm).
      "feedback_distillation": true
    },

    // ── Index Pipeline ──────────────────────────────────────────────────────
    // Operations during `akm index`. Replaces v1's three index-time flags
    // (memory_inference, graph_extraction, metadata_enhance).
    "index": {
      // Memory inference — extract structured metadata when indexing memories.
      "memory_inference": true,

      // Graph extraction during indexing. Pinned to the cheap mini model;
      // structured JSON task that benefits from supportsJsonSchema.
      "graph_extraction": { "profile": "openai-mini" },

      // Metadata enhancement: disabled — local embedding handles it here.
      "metadata_enhance": false
    },

    // ── Search Pipeline ─────────────────────────────────────────────────────
    // Operations during `akm search` / `akm curate`. Replaces v1's curate_rerank.
    "search": {
      // Curate rerank: enabled with default profile; improves search quality at low cost.
      "curate_rerank": true
    }
  },

  // ── Embedding (unchanged from v1) ───────────────────────────────────────────
  "embedding": {
    "endpoint": "http://localhost:1234/v1/embeddings",
    "model": "text-embedding-qwen3-embedding-0.6b",
    "provider": "lmstudio",
    "dimension": 1024
  },

  // ── Other top-level keys (unchanged from v1) ────────────────────────────────
  "stashDir": "/home/founder3/akm",
  "semanticSearchMode": "auto",
  "output": {
    "format": "json",
    "detail": "brief"
  }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TASK YAML — Schedules and per-task dispatch live in the stash, not config.
// ═══════════════════════════════════════════════════════════════════════════════
//
// Example task at <stash>/tasks/improve-hourly.yml (NOT in akm config):
//
//   name: improve-hourly
//   description: Hourly improve cycle with safe-auto-accept
//   schedule: "7 * * * *"          # cron — owned by the task, not akm config
//   mode: agent                    # how this task is dispatched
//   profile: opencode-default      # which profile from akm config.profiles.agent
//   command: akm improve --auto-accept safe
//
// The task runner reads `mode` and `profile` from the YAML and resolves
// against the profile pools declared in this akm config. No config.tasks
// section exists.

// ═══════════════════════════════════════════════════════════════════════════════
// CONTRASTING EXAMPLES — "What would change if I wanted X?"
// ═══════════════════════════════════════════════════════════════════════════════

/*
── Example A: Preset "fast" ──────────────────────────────────────────────────
  Simplest possible config — preset "fast" makes every improve process use
  mode=llm + profile=defaults.llm, so features.improve can be empty (or omitted).

  {
    "configVersion": 2,
    "profiles": {
      "llm": {
        "openai-mini": {
          "endpoint": "https://api.openai.com/v1/chat/completions",
          "model": "gpt-4o-mini",
          "apiKey": "${OPENAI_API_KEY}",
          "temperature": 0.3,
          "supportsJsonSchema": true
        }
      },
      "agent": {
        "opencode-default": { "platform": "opencode", "bin": "opencode", "args": ["run"] }
      }
    },
    "defaults": {
      "llm": "openai-mini",
      "agent": "opencode-default",
      "improve": { "preset": "fast" }
    }
    // features can be omitted entirely — the preset fills it in at load time.
  }

── Example B: Local-only / air-gapped ────────────────────────────────────────
  No external API. Everything routes through LM Studio. propose stays on
  agent path so opencode tool access still works.

  {
    "configVersion": 2,
    "profiles": {
      "llm": {
        "lmstudio-local": {
          "endpoint": "http://192.168.0.99:1234/v1/chat/completions",
          "model": "mistralai/ministral-3b",
          "temperature": 0.3,
          "contextLength": 131072
        }
      },
      "agent": {
        "opencode-default": { "platform": "opencode", "bin": "opencode", "args": ["run"] }
      }
    },
    "defaults": {
      "llm": "lmstudio-local",
      "agent": "opencode-default",
      "improve": { "preset": "custom" }
    },
    "features": {
      "improve": {
        "reflect":              { "mode": "llm",   "profile": "lmstudio-local" },
        "distill":              { "mode": "llm",   "profile": "lmstudio-local" },
        "memory_consolidation": { "mode": "llm",   "profile": "lmstudio-local" },
        "propose":              { "mode": "agent", "profile": "opencode-default" },
        "memory_improve":       { "mode": "llm",   "profile": "lmstudio-local" }
      }
    }
  }

── Example C: Minimal viable config ──────────────────────────────────────────
  Only the keys that are absolutely required. Everything else resolves to
  built-in defaults. The loader infers mode from defaults.llm being set.

  {
    "configVersion": 2,
    "profiles": {
      "llm": {
        "openai-mini": {
          "endpoint": "https://api.openai.com/v1/chat/completions",
          "model": "gpt-4o-mini",
          "apiKey": "${OPENAI_API_KEY}"
        }
      }
    },
    "defaults": { "llm": "openai-mini" }
  }

── Example D: Cooldown override only ─────────────────────────────────────────
  All you want to change is how often reflect re-visits memories. The rest
  uses built-in defaults. Note how the tuning collocates with the process.

  {
    "configVersion": 2,
    "profiles": {
      "llm": { "openai-mini": { "endpoint": "...", "model": "gpt-4o-mini",
                                 "apiKey": "${OPENAI_API_KEY}" } }
    },
    "defaults": { "llm": "openai-mini" },
    "features": {
      "improve": {
        "reflect": {
          "options": {
            "cooldown": { "memory": 1, "lesson": 3 }
          }
        }
      }
    }
  }
*/
