{
  "name": "agentikit",
  "version": "0.0.9",
  "type": "module",
  "description": "CLI tool to search, open, and run extension assets from an agentikit stash directory.",
  "keywords": [
    "agentikit",
    "ai-agent",
    "agent-framework",
    "developer-tools",
    "cli",
    "tools",
    "skills",
    "commands"
  ],
  "homepage": "https://github.com/itlackey/agentikit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itlackey/agentikit.git"
  },
  "bugs": {
    "url": "https://github.com/itlackey/agentikit/issues"
  },
  "license": "CC-BY-4.0",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "bin": {
    "akm": "dist/src/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun run tsc --project ./tsconfig.json --emitDeclarationOnly false --declaration false --outDir dist",
    "build:types": "bun run tsc --project ./tsconfig.json",
    "test": "bun test",
    "prepublishOnly": "bun run build && bun run build:types"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.0"
  },
  "dependencies": {
    "citty": "^0.2.1"
  }
}
