{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": false,
    "emitDeclarationOnly": false,
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun-types"],
    "baseUrl": ".",
    "paths": {
      "@core/*": ["src/core/*"],
      "@storage/*": ["src/storage/*"],
      "@indexer/*": ["src/indexer/*"],
      "@output/*": ["src/output/*"],
      "@llm/*": ["src/llm/*"],
      "@improve/*": ["src/commands/*"],
      "@proposal/*": ["src/commands/*"],
      "@sources/*": ["src/commands/*"],
      "@env/*": ["src/commands/*"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
